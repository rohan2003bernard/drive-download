# Copy this file to .env and fill values
# Path to your Google service account JSON file
GOOGLE_SERVICE_ACCOUNT_FILE=client_secrets.json
# Or store raw service account JSON directly in .env.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ID of the Google Drive folder containing the images
DRIVE_FOLDER_ID=

# Local output directory
OUTPUT_DIR=downloads

# File containing basenames (one per line) to download
NAMES_FILE=names.txt

# API URL for the Next.js frontend to call
NEXT_PUBLIC_API_URL=
